# --- Server ---
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# --- CORS ---
# Comma-separated list of allowed origins. Use "*" for any (dev only).
CORS_ORIGIN=http://localhost:3000

# --- Redis ---
REDIS_URL=redis://127.0.0.1:6379

# --- Auth (JWT) ---
# Use a long random string in production (>= 32 chars).
JWT_SECRET=change-me-please-use-a-long-random-string
# Access token TTL (e.g. "15m", "1h", "7d").
JWT_EXPIRES_IN=2h

# --- Admin bootstrap (created at first boot if missing) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMeNow!123

# --- Blockchain (relayer = contract owner) ---
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# --- Voter commitment salt (must be kept secret and stable) ---
VOTER_HASH_SALT=replace-with-a-32-byte-random-secret

# --- Rate limiting ---
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW=1 minute
RATE_LIMIT_VOTE_MAX=3
RATE_LIMIT_VOTE_WINDOW=1 minute
